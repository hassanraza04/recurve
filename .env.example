# Copy to .env (root, for the Python services) and web/.env.local (for Next.js).
# Never commit real values. Secrets come from a secret manager in the cloud.

# ─── Data API + pipeline (root .env) ──────────────────────────────────────────
# control-plane Postgres
RECURVE_DATABASE_URL=postgresql+psycopg://recurve:recurve@localhost:5432/recurve

# local warehouse (DuckDB file); BigQuery is used in the live deploy
RECURVE_WAREHOUSE_PATH=data/local/recurve.duckdb

# Fernet key for encrypting connection credentials at rest. Generate with:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
RECURVE_FERNET_KEY=

# CORS: which web origin(s) may call the API
RECURVE_ALLOWED_ORIGINS=["http://localhost:3000"]
RECURVE_ENVIRONMENT=local

# BigQuery (live deploy only)
RECURVE_BQ_PROJECT=
RECURVE_BQ_DATASET=recurve
RECURVE_BQ_KEYFILE=
RECURVE_BQ_LOCATION=US

# ─── Next.js app (web/.env.local) ─────────────────────────────────────────────
# Clerk auth — get keys at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# where the web app reaches the Data API
NEXT_PUBLIC_API_URL=http://localhost:8000
